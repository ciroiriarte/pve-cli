<services>
  <!-- Mirrors the working pattern from home:ciriarte:network-tools: tar_scm
       emits a .tar directly (the standalone `tar` service is not available on
       api.opensuse.org), set_version patches the spec/changelog version,
       recompress gzips it, and go_modules vendors deps for the offline build. -->
  <service name="tar_scm">
    <param name="scm">git</param>
    <param name="url">https://github.com/ciroiriarte/pve-cli</param>
    <param name="version">0.5.3</param>
    <param name="revision">v0.5.3</param>
    <param name="filename">pve-cli</param>
  </service>
  <service name="set_version">
    <param name="basename">pve-cli</param>
  </service>
  <service name="recompress">
    <param name="file">*.tar</param>
    <param name="compression">gz</param>
  </service>
  <service name="go_modules">
    <param name="compression">gz</param>
  </service>
</services>
